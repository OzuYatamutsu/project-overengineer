{
  "name": "@project-overengineer/ocr-worker",
  "version": "1.4.0",
  "description": "An OCR service worker that parses images into structured text",
  "main": "worker.ts",
  "scripts": {
    "dev": "tsx watch worker.ts",
    "build": "tsc && cp tests/test-image.base64 dist/tests",
    "start": "node dist/worker.js",
    "lint": "eslint *.ts",
    "test": "pnpm build && TS_NODE_TRANSPILE_ONLY=1 playwright test -c playwright.config.ts"
  },
  "dependencies": {
    "@project-overengineer/shared-lib": "workspace:*",
    "undici": "^7.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
